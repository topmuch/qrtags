// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// User model - supports superadmin, admin, agent, and agency users
model User {
  id              String        @id @default(cuid())
  email           String        @unique
  name            String?
  password        String?
  role            String        @default("agency") // "superadmin" | "admin" | "agent" | "agency"
  agencyId        String?
  agency          Agency?       @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  roleId          String?
  roleRelation    Role?         @relation(fields: [roleId], references: [id])
  sessions        Session[]
  loginLogs       LoginLog[]
  assignedLeads   Lead[]        @relation("AssignedLeads")
  observations    Observation[]
  dailyReports    DailyReport[]
  blogPosts       BlogPost[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

// Session model - secure HTTP-only cookie based sessions
model Session {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userAgent    String?  // Browser identification
  ipAddress    String?  // IP address at login
  lastActivity DateTime @default(now()) // Last activity timestamp
  expiresAt    DateTime
  createdAt    DateTime @default(now())
}

// LoginLog model - audit trail for all login attempts
model LoginLog {
  id           String    @id @default(cuid())
  userId       String?
  user         User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  email        String    // Email used for login attempt
  success      Boolean   @default(false) // Whether login succeeded
  failureReason String?  // Reason for failure if applicable
  ipAddress    String?   // IP address
  userAgent    String?   // Browser/client info
  country      String?   // Country from IP
  city         String?   // City from IP
  createdAt    DateTime  @default(now())
}

// Agency model - multi-business (travel, hotel, bus, school, medical, company, event)
model Agency {
  id              String    @id @default(cuid())
  name            String
  slug            String    @unique
  agencyType      String    @default("travel") // "travel" | "hotel" | "bus" | "school" | "medical" | "company" | "event"
  email           String?
  phone           String?
  address         String?
  logoUrl         String?
  primaryColor    String    @default("#2563EB")
  secondaryColor  String    @default("#F97316")
  customMessage   String?   // Message personnalisé page de scan
  active          Boolean   @default(true)
  plan            String    @default("free") // "free" | "pro" | "enterprise"
  onboardingCompleted Boolean  @default(false)
  maxTags         Int       @default(5) // Max QR tags based on plan
  tagsUsed        Int       @default(0) // Currently used tags
  createdAt       DateTime  @default(now())
  baggages        Baggage[]
  users           User[]
  invoices        Invoice[]
  customFields    AgencyCustomField[]
  subscriptions   Subscription[]
  payments        Payment[]
  wallet          Wallet?
  smsCredits      SmsCredit[]
  bookings        Booking[]
}

// Baggage model - main entity for lost object tracking
model Baggage {
  id                String    @id @default(cuid())
  reference         String    @unique // BAG26-MLQGY7
  type              String    @default("standard") // "standard" (legacy: "hajj" | "voyageur")
  setId             String?   // Groups QR codes together (e.g., SET-2026-0966)
  agencyId          String?
  travelerFirstName String? // Owner first name
  travelerLastName  String? // Owner last name
  whatsappOwner     String?
  baggageIndex      Int       @default(1) // 1, 2, 3 (order: 1 = primary)
  objectCategory    String?   // "ordinateur" | "telephone" | "ecouteurs" | "passeport" | "carte_identite" | etc.
  status            String    @default("pending_activation") // pending_activation, active, scanned, lost, found, blocked

  // ─── LOST-BAGGAGE-FEATURE: Description fields ───
  itemDescription   String?   // Free text description of the item
  itemColor         String?   // Color of the item (e.g., "Noir", "Rouge", "Bleu marine")
  itemBrand         String?   // Brand of the item (e.g., "Samsonite", "Apple", "Louis Vuitton")
  identificationMark String?  // Distinguishing mark (e.g., "Bandana rouge sur la poignée", "Sticker émoji")

  // ─── Legacy transport fields (kept for backward compatibility) ───
  transportMode     String?   // Legacy: "flight" | "train" | "boat" | "bus"
  airlineName       String?
  flightNumber      String?
  trainCompany      String?
  trainNumber       String?
  shipName          String?
  shipCabin         String?
  busCompany        String?
  busLineNumber     String?
  baggageType       String?   // Legacy: "cabine" or "soute"
  destination       String?   // Legacy
  departureDate     DateTime? // Legacy
  departureTime     String?   // Legacy

  // ─── Tracking fields ───
  createdAt         DateTime  @default(now())
  expiresAt         DateTime?
  lastScanDate      DateTime?
  lastLocation      String?
  declaredLostAt    DateTime? // Timestamp when baggage was declared lost
  foundAt           DateTime? // Timestamp when baggage was found
  // Founder information (person who found the baggage)
  founderName       String?   // Name of the finder
  founderPhone      String?   // WhatsApp number of the finder
  founderAt         DateTime? // Timestamp when founder info was submitted
  agency            Agency?   @relation(fields: [agencyId], references: [id], onDelete: SetNull)
  scanLogs          ScanLog[]
  customData        String?   // JSON: données dynamiques par type d'agence
}

// ScanLog model - tracks all scans for audit
model ScanLog {
  id          String   @id @default(cuid())
  baggageId   String
  ipAddress   String?
  country     String?
  city        String?
  latitude    Float?
  longitude   Float?
  location    String?  // Selected location (Jeddah, Médine, etc.)
  message     String?  // Optional message from finder
  createdAt   DateTime @default(now())
  baggage     Baggage  @relation(fields: [baggageId], references: [id], onDelete: Cascade)

  // ─── Champs IA (Groq) ───
  whatsappStatus  String?   // "sent" | "delivered" | "failed" | "fallback" | "queued" | "read"
  aiAnalysis      Json?     // ScanAIAnalysis: { type, color, size, confidence, isDuplicate, description?, analyzedAt }
  groqUsed        Boolean   @default(false) // true si Groq a été utilisé pour ce scan
  groqLatencyMs   Int?      // Temps de réponse Groq en ms
  aiMessageUsed   Boolean   @default(false) // true si le message WhatsApp a été généré par IA
  groqModelUsed   String?   // Modèle Groq utilisé (ex: "llama-3.3-70b-versatile")
  wakitMessageId  String?   // ID de retour Wakit pour tracking croisé

  // ─── Contexte du scan ───
  context     String?   // "departure_airport_urgent" | "arrival_airport" | "in_transit" | "static_location"
  finderName  String?   // Nom du trouveur (dupliqué ici pour l'API suivi)
  finderPhone String?   // Téléphone du trouveur (dupliqué ici pour l'API suivi)
}

// Settings model - system configuration
model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

// Page model - CMS pages
model Page {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  content   String   // HTML or Markdown content
  published Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Banner model - dashboard announcements
model Banner {
  id        String   @id @default(cuid())
  type      String   // "header" or "footer"
  content   String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// FeatureFlag model - modular feature toggles
model FeatureFlag {
  id          String   @id @default(cuid())
  key         String   @unique // ex: "whatsapp_automated"
  label       String   // "Envoi WhatsApp automatisé"
  description String   // Clear description for admins
  category    String   @default("general") // "communication", "geolocation", "export", "notifications"
  enabled     Boolean  @default(false)
  icon        String?  // Icon name for UI
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Message model - contact, partner requests, agency orders, assistance
// Message types:
// - "contact": Contact form from public website
// - "partenaire": Partner registration requests
// - "commande_agence": QR code orders from agencies
// - "assistance_agence": Support messages from agencies to superadmin
// - "reponse_assistance": Replies from superadmin to agencies
// - "message_superadmin": Messages initiated by superadmin for specific agencies
model Message {
  id          String   @id @default(cuid())
  type        String   // "contact", "partenaire", "commande_agence", "assistance_agence", "reponse_assistance", "message_superadmin"
  status      String   @default("non_lu") // "non_lu", "lu", "traite"
  senderName  String?
  senderEmail String?
  senderPhone String?
  agencyId    String?  // lien vers Agence (si commande agence ou assistance)
  recipientAgencyId String? // Pour les messages du superadmin vers une agence spécifique
  subject     String?  // Subject line for assistance messages
  content     String   // JSON ou texte brut
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Notification model - real-time alerts for SuperAdmin
// Notification types:
// - "baggage_declared_lost": Agency declared a baggage as lost
// - "baggage_found": Lost baggage was found
// - "new_assistance_message": New assistance message from agency
// - "urgent_scan": Urgent scan on lost baggage
model Notification {
  id          String   @id @default(cuid())
  type        String   // "baggage_declared_lost", "baggage_found", "new_assistance_message", "urgent_scan"
  userId      String?  // null = broadcast to all superadmins
  agencyId    String?  // Reference to agency if applicable
  baggageId   String?  // Reference to baggage if applicable
  message     String   // Notification message
  data        String?  // JSON additional data
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// EmailSettings model - SMTP configuration
model EmailSettings {
  id              String   @id @default(cuid())
  provider        String   @default("console") // "console" or "smtp"
  fromEmail       String   @default("noreply@qrtags.com")
  fromName        String   @default("QRTags")
  recipientEmail  String?  // Destination for admin notification emails
  // SMTP settings
  smtpHost        String?
  smtpPort        Int?
  smtpUser        String?
  smtpPassword    String?
  smtpEncryption  String   @default("tls") // "tls", "ssl", "none"
  // Status
  isActive        Boolean  @default(true)
  lastTestAt      DateTime?
  lastTestStatus  String?  // "success", "failed"
  lastTestError   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// EmailLog model - tracks all sent emails
model EmailLog {
  id          String   @id @default(cuid())
  to          String
  subject     String
  type        String   // "verification", "password_reset", "notification", "invoice", "test", "welcome"
  status      String   @default("pending") // "pending", "sent", "failed"
  error       String?
  userId      String?
  agencyId    String?
  data        String?  // JSON for additional data
  sentAt      DateTime?
  createdAt   DateTime @default(now())
}

// EmailToken model - for email verification and password reset
model EmailToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  type      String   // "email_verification", "password_reset"
  code      String?  // 6-digit code for verification
  expiresAt DateTime
  used      Boolean  @default(false)
  usedAt    DateTime?
  createdAt DateTime @default(now())
}

// Invoice model - for agency billing
model Invoice {
  id              String   @id @default(cuid())
  number          String   @unique
  agencyId        String
  agency          Agency   @relation(fields: [agencyId], references: [id])
  amount          Float
  currency        String   @default("EUR")
  status          String   @default("pending") // "pending", "paid", "cancelled"
  description     String?
  items           String   // JSON array of invoice items
  dueDate         DateTime?
  paidAt          DateTime?
  paymentMethod   String?
  subscriptionId  String?
  subscription    Subscription?  @relation(fields: [subscriptionId], references: [id])
  payments        Payment[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Lead model - CRM leads/prospects
model Lead {
  id            String        @id @default(cuid())
  name          String
  email         String
  phone         String?
  company       String?
  status        String        @default("new") // "new", "contacted", "in_discussion", "qualified", "converted", "lost"
  source        String?       // "website", "referral", "social", "event", "other"
  notes         String?
  agencyId      String?       // Link to agency if converted
  assignedToId  String?       // Agent assigned to this lead
  assignedTo    User?         @relation("AssignedLeads", fields: [assignedToId], references: [id], onDelete: SetNull)
  observations  Observation[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

// Observation model - tracks interactions with leads
model Observation {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type      String   // "note", "rdv", "appel", "email", "whatsapp"
  content   String   // Observation content
  date      DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

// DailyReport model - agent daily activity reports
model DailyReport {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime @default(now())
  content   String   // Free text report
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, date])
}

// Advertisement model - promotional banners for agencies
model Advertisement {
  id          String   @id @default(cuid())
  title       String
  description String?
  imageUrl    String   // URL to banner image
  linkUrl     String?  // Click destination URL
  linkTarget  String   @default("_blank") // "_blank" or "_self"
  
  // Position - only footer
  position    String   @default("footer") // "footer", "header", "sidebar"
  
  // Targeting
  targetScope String   @default("all") // "all", "agency", "agents"
  agencyId    String?  // Specific agency if targetScope = "agency"
  
  // Scheduling
  startDate   DateTime
  endDate     DateTime?
  
  // Status
  status      String   @default("draft") // "draft", "active", "paused", "expired"
  priority    Int      @default(0) // Higher = more prominent
  
  // Statistics
  impressions Int      @default(0)
  clicks      Int      @default(0)
  
  // Metadata
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  adImpressions AdImpression[]
}

// AdImpression model - tracks each impression and click
model AdImpression {
  id              String   @id @default(cuid())
  advertisementId String
  advertisement   Advertisement @relation(fields: [advertisementId], references: [id], onDelete: Cascade)
  
  // Viewer info
  userId          String?  // Logged-in user who viewed
  agencyId        String?  // Agency of the viewer
  userRole        String?  // Role of the viewer
  
  // Action
  action          String   // "impression" or "click"
  
  // Context
  ipAddress       String?
  userAgent       String?
  
  createdAt       DateTime @default(now())
}

// BlogPost model - internal blog for agencies
model BlogPost {
  id            String   @id @default(cuid())
  title         String
  slug          String   @unique
  content       String   // HTML content from rich editor
  excerpt       String?  // Short summary
  coverImage    String?  // URL to cover image
  
  // Categorization
  category      String   @default("actualites") // "actualites", "conseils", "hajj", "mises_a_jour"
  
  // Publishing
  status        String   @default("draft") // "draft", "published"
  publishedAt   DateTime?
  
  // Author
  authorId      String?
  author        User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
  
  // Metrics
  views         Int      @default(0)
  
  // Metadata
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  // Relations
  blogViews     BlogView[]
}

// BlogView model - track article views
model BlogView {
  id          String   @id @default(cuid())
  postId      String
  post        BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  
  // Viewer info
  userId      String?
  agencyId    String?
  
  // Context
  ipAddress   String?
  userAgent   String?
  
  createdAt   DateTime @default(now())
}

// SystemLog model - centralized system logging for monitoring
// AgencyCustomField - champs dynamiques par type d'agence
model AgencyCustomField {
  id          String   @id @default(cuid())
  agencyType  String   // "hotel" | "bus" | "school" | "medical" | "company" | "event" | "travel"
  fieldName   String   // "guest_name", "room_number", etc.
  fieldLabel  String   // "Nom du client", "N° chambre", etc.
  fieldType   String   @default("text") // "text" | "tel" | "email" | "date" | "number"
  isRequired  Boolean  @default(false)
  sortOrder   Int      @default(0)
  agency      Agency?  @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  agencyId    String?
  createdAt   DateTime @default(now())

  @@unique([agencyType, fieldName, agencyId])
}

model SystemLog {
  id        String   @id @default(cuid())
  level     String   // "info" | "warn" | "error" | "fatal"
  message   String
  source    String   // ex: "api/activate", "diagnostic", "chatbot"
  metadata  String?  // JSON string with contextual data (sanitized)
  createdAt DateTime @default(now())

  @@index([level])
  @@index([source])
  @@index([createdAt])
}

// Subscription model - agency subscription plans
model Subscription {
  id            String   @id @default(cuid())
  agencyId      String
  agency        Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  plan          String   @default("free") // "free" | "pro" | "enterprise"
  status        String   @default("active") // "active" | "paused" | "cancelled" | "expired"
  startDate     DateTime @default(now())
  endDate       DateTime?
  amount        Float    @default(0)
  currency      String   @default("XOF") // FCFA
  paymentMethod String?  // "wave" | "orange_money" | "mtn_money" | "cinetpay" | "card"
  autoRenew     Boolean  @default(false)
  cancelledAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  invoices      Invoice[]
  payments      Payment[]
}

// Payment model - payment transactions
model Payment {
  id              String   @id @default(cuid())
  agencyId        String?
  agency          Agency?  @relation(fields: [agencyId], references: [id], onDelete: SetNull)
  subscriptionId  String?
  subscription    Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  amount          Float
  currency        String   @default("XOF")
  method          String   // "wave" | "orange_money" | "mtn_money" | "cinetpay" | "card" | "wallet"
  status          String   @default("pending") // "pending" | "processing" | "success" | "failed" | "refunded"
  transactionId   String?  // External transaction ID from payment provider
  provider        String?  // "cinetpay" | "wave" etc.
  description     String?
  metadata        String?  // JSON with provider-specific data
  paidAt          DateTime?
  createdAt       DateTime @default(now())

  invoiceId       String?
  invoice         Invoice?  @relation(fields: [invoiceId], references: [id])
  bookings        Booking[]
}

// Wallet model - agency prepaid wallet
model Wallet {
  id              String   @id @default(cuid())
  agencyId        String   @unique
  agency          Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  balance         Float    @default(0)
  totalRecharged  Float    @default(0)
  totalSpent      Float    @default(0)
  currency        String   @default("XOF")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  transactions    WalletTransaction[]
}

// WalletTransaction model - wallet movements
model WalletTransaction {
  id              String   @id @default(cuid())
  walletId        String
  wallet          Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)
  type            String   // "recharge" | "purchase" | "refund" | "adjustment"
  amount          Float
  balanceBefore   Float
  balanceAfter    Float
  description     String?
  referenceId     String?  // Link to Payment or other entity
  referenceType   String?  // "payment" | "subscription" | "manual"
  createdAt       DateTime @default(now())

  @@index([walletId])
  @@index([type])
  @@index([createdAt])
}

// SmsCredit model - SMS credits management
model SmsCredit {
  id              String   @id @default(cuid())
  agencyId        String
  agency          Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  balance         Int      @default(0)
  totalPurchased  Int      @default(0)
  totalUsed       Int      @default(0)
  lowBalanceAlert Boolean  @default(true)
  alertThreshold  Int      @default(10)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([agencyId])
}

// Booking model - tag orders/purchases
model Booking {
  id              String   @id @default(cuid())
  agencyId        String?
  agency          Agency?  @relation(fields: [agencyId], references: [id], onDelete: SetNull)
  reference       String   @unique // "CMD-2025-XXXXX"
  plan            String   @default("pro") // what was ordered
  quantity        Int      @default(1) // number of tags
  amountPerTag    Float
  totalAmount     Float
  currency        String   @default("XOF")
  status          String   @default("pending") // "pending" | "paid" | "processing" | "completed" | "cancelled"
  paymentId       String?
  payment         Payment? @relation(fields: [paymentId], references: [id])
  paymentMethod   String?
  paidAt          DateTime?
  completedAt     DateTime?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([agencyId])
  @@index([status])
  @@index([createdAt])
}

// Role model - stored in DB for flexibility
model Role {
  id          String   @id @default(cuid())
  name        String   @unique // "superadmin" | "admin" | "agent" | "agency"
  label       String   // Display name
  description String?
  level       Int      @default(0) // Higher = more permissions (superadmin=100, admin=80, agent=50, agency=10)
  isSystem    Boolean  @default(false) // System roles cannot be deleted
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       User[]
  rolePermissions RolePermission[]
}

// Permission model - granular permissions stored in DB
model Permission {
  id          String   @id @default(cuid())
  key         String   @unique // "view_dashboard", "manage_baggages", etc.
  label       String   // Display name "Voir le dashboard"
  category    String   @default("general") // "general" | "baggage" | "agency" | "user" | "report" | "message" | "setting" | "crm" | "monitoring"
  description String?
  createdAt   DateTime @default(now())

  rolePermissions RolePermission[]
}

// RolePermission - many-to-many junction
model RolePermission {
  id           String   @id @default(cuid())
  roleId       String
  role         Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())

  @@unique([roleId, permissionId])
}

// Checklist model - public travel inventory checklists generated by passengers
// Each checklist is identified by a 6-char public code (URL: /checklist/[code])
// and protected by an 8-char verification key required to view the PDF content.
model Checklist {
  id              String   @id @default(cuid())
  // Public 6-char code (base32, no I/O/0/1) — used in URL /checklist/[code]
  code            String   @unique
  // 8-char verification key required to view/download the PDF
  verificationKey String
  // Passenger info
  firstName       String
  lastName        String
  email           String
  departureDate   String   // ISO date string (yyyy-mm-dd) — kept as string for simplicity
  destinationCountry String
  airline         String?
  // Selected items (JSON array of {category, name, qty, checked})
  items           String   // JSON string
  itemsCount      Int      @default(0)
  // PDF generation metadata
  pdfPath         String?  // Optional on-disk path; null = generate on-demand
  pdfSizeBytes    Int?     @default(0)
  // Tracking
  viewCount       Int      @default(0)
  lastViewedAt    DateTime?
  emailSent       Boolean  @default(false)
  emailSentAt     DateTime?
  // Timestamps
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([code])
  @@index([email])
  @@index([createdAt])
}
