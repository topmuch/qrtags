# ═══════════════════════════════════════════════════════════════
# QRTags — Production Environment Variables
# ═══════════════════════════════════════════════════════════════
# Configure these in Coolify → Service → Environment
# ═══════════════════════════════════════════════════════════════

# ─── Application ───
# Public URL of your deployed app (e.g. https://qrtags.com)
NEXT_PUBLIC_BASE_URL=https://your-domain.com

# ─── Auth (NextAuth) ───
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=REPLACE_WITH_SECURE_STRING
NEXTAUTH_URL=https://your-domain.com

# ─── Database (SQLite — path inside container) ───
DATABASE_URL=file:/app/data/qrtags.db

# ─── Encryption (generate: openssl rand -base64 32) ───
ENCRYPTION_KEY=REPLACE_WITH_SECURE_STRING

# ─── WAKIT (WhatsApp Business API) ───
# Leave empty to disable WhatsApp alerts
WAKIT_API_KEY=
WAKIT_BASE_URL=https://api.wakit.ai/v1
WAKIT_PHONE_NUMBER_ID=
WAKIT_TEMPLATE_SCAN_ALERT=baggage_scan_alert
WAKIT_TIMEOUT_MS=10000

# ─── GROQ (AI Chatbot) ───
# Leave empty to disable AI features
GROQ_API_KEY=
GROQ_MODEL_CHAT=llama3-8b-8192
GROQ_MODEL_ANALYSIS=llama3-8b-8192
GROQ_TIMEOUT_MS=30000
GROQ_AI_ENABLED=true
GROQ_CHAT_ENABLED=true
GROQ_SCAN_GUARD_ENABLED=true
GROQ_AUTO_TRANSLATE_ENABLED=true